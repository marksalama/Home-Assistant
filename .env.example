# ---------------------------------------------------------------------------
# Home Assistant MCP server configuration
# Copy this file to .env and fill in your own values.
# ---------------------------------------------------------------------------

# Base URL of your Home Assistant instance (no trailing /api).
# Examples: http://homeassistant.local:8123  |  https://ha.example.com
HA_URL=http://homeassistant.local:8123

# Long-Lived Access Token.
# Create one in Home Assistant: click your user (bottom-left) ->
# Security tab -> "Long-lived access tokens" -> "Create token".
HA_TOKEN=

# Verify TLS certificates for https URLs (true/false). Set to false only for
# self-signed certs on a trusted local network.
HA_VERIFY_SSL=true

# Timeout in seconds for REST/WebSocket calls.
HA_TIMEOUT=30

# ---------------------------------------------------------------------------
# Safety & security
# ---------------------------------------------------------------------------
# Read-only mode: when true, every tool that would change Home Assistant is
# blocked (great for a cautious "look but don't touch" first run).
HA_READ_ONLY=false

# Keep local snapshots of config files before they are overwritten/deleted so
# edits can be rolled back with restore_config_file.
HA_SNAPSHOTS=true
# Where snapshots are stored (defaults to ~/.ha-mcp/snapshots).
# HA_SNAPSHOT_DIR=

# Automatically create a backup before installing add-on / update-entity updates.
HA_AUTO_BACKUP_BEFORE_UPDATE=false

# ---------------------------------------------------------------------------
# Tool filtering
# ---------------------------------------------------------------------------
# Comma-separated list of tools to disable. Mutually exclusive with HA_ENABLED_TOOLS.
# HA_DISABLED_TOOLS=reboot_host,restore_backup
# Comma-separated whitelist: only these tools are exposed (overrides disabled list).
# HA_ENABLED_TOOLS=list_entities,get_state,call_service

# ---------------------------------------------------------------------------
# Tool search / discovery mode (recommended for smaller LLMs like Haiku,
# Gemini, OpenAI-compatible local models)
# ---------------------------------------------------------------------------
# Replace the full tool catalog with search-based discovery proxy tools.
# HA_ENABLE_TOOL_SEARCH=false
# Max results returned by search_tools (range 2-10).
# HA_TOOL_SEARCH_MAX_RESULTS=5
# Comma-separated tool names to keep always visible in search mode.
# HA_PINNED_TOOLS=list_entities,get_overview,get_state

# ---------------------------------------------------------------------------
# HTTP transport (optional — default is stdio)
# ---------------------------------------------------------------------------
# Choose "stdio", "sse" or "http". HTTP mode exposes /mcp endpoint.
# HA_TRANSPORT=stdio
# HA_HOST=127.0.0.1
# HA_PORT=8765
# Optional: bearer token for HTTP-mode auth (leave empty = no auth).
# HA_HTTP_TOKEN=

# ---------------------------------------------------------------------------
# YAML / raw file access (optional but enables editing configuration.yaml etc.)
# Choose ONE backend: "none" (default), "local" or "ssh".
# ---------------------------------------------------------------------------
HA_FILES_BACKEND=none

# --- local backend ---
# Use this when the HA config directory is reachable on the machine running
# this MCP server (e.g. a mounted Samba share, or HA Core in a venv).
# HA_FILES_BACKEND=local
# HA_CONFIG_DIR=/path/to/homeassistant/config

# --- ssh backend (recommended for HA OS / Supervised) ---
# Install the "Advanced SSH & Web Terminal" add-on, then point here.
# HA_FILES_BACKEND=ssh
# HA_SSH_HOST=homeassistant.local
# HA_SSH_PORT=22
# HA_SSH_USER=root
# HA_SSH_PASSWORD=
# Or use a key instead of a password:
# HA_SSH_KEY_FILE=/home/you/.ssh/id_ed25519
# Remote config directory (the SSH add-on maps it to /config).
# HA_SSH_CONFIG_DIR=/config
