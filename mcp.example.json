{
  "mcpServers": {
    "home-assistant": {
      "command": "ha-mcp",
      "args": [],
      "env": {
        "HA_URL": "http://homeassistant.local:8123",
        "HA_TOKEN": "PASTE_YOUR_LONG_LIVED_TOKEN_HERE",
        "HA_VERIFY_SSL": "true",
        "HA_FILES_BACKEND": "ssh",
        "HA_SSH_HOST": "homeassistant.local",
        "HA_SSH_PORT": "22",
        "HA_SSH_USER": "root",
        "HA_SSH_PASSWORD": "PASTE_SSH_ADDON_PASSWORD_HERE",
        "HA_SSH_CONFIG_DIR": "/config",
        "HA_READ_ONLY": "false",
        "HA_SNAPSHOTS": "true",
        "HA_AUTO_BACKUP_BEFORE_UPDATE": "true",
        "HA_DISABLED_TOOLS": "",
        "HA_ENABLE_TOOL_SEARCH": "false",
        "HA_PINNED_TOOLS": ""
      }
    },
    "home-assistant-http": {
      "command": "ha-mcp",
      "args": ["--transport", "http", "--host", "127.0.0.1", "--port", "8765"],
      "env": {
        "HA_URL": "http://homeassistant.local:8123",
        "HA_TOKEN": "PASTE_YOUR_LONG_LIVED_TOKEN_HERE",
        "HA_VERIFY_SSL": "true",
        "HA_FILES_BACKEND": "ssh",
        "HA_SSH_HOST": "homeassistant.local",
        "HA_SSH_PORT": "22",
        "HA_SSH_USER": "root",
        "HA_SSH_PASSWORD": "PASTE_SSH_ADDON_PASSWORD_HERE",
        "HA_SSH_CONFIG_DIR": "/config",
        "HA_READ_ONLY": "false",
        "HA_SNAPSHOTS": "true",
        "HA_AUTO_BACKUP_BEFORE_UPDATE": "true"
      }
    }
  }
}
